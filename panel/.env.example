APP_NAME=GPanel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8442

LOG_CHANNEL=stack
LOG_LEVEL=info

# Banco do painel — SQLite (sem dependência circular)
DB_CONNECTION=sqlite
DB_DATABASE=/gpanel/storage/database.sqlite

# Filas — database driver (usa o mesmo SQLite)
QUEUE_CONNECTION=database

# Cache
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=480

# Redis (opcional, para cache avançado)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Node.js helper WebSocket
GPANEL_WS_PORT=3001
GPANEL_WS_HOST=127.0.0.1

# Porta do painel
GPANEL_PORT=8442

# Diretório raiz do GPanel
GPANEL_DIR=/gpanel
